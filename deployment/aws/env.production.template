AUTHCLAW_ENV=production
AUTHCLAW_ALLOWED_ORIGINS=https://app.authclaw.example.com
AUTHCLAW_RATE_LIMIT_PER_MINUTE=120
ENABLE_DEV_MODE=false
SKIP_EMAIL_DELIVERY_FOR_TESTING=false
SKIP_DOMAIN_VERIFICATION=false
DISABLE_MFA_FOR_TESTING=false

DATABASE_URL=postgresql://authclaw:CHANGE_ME@authclaw-rds.example:5432/authclaw
POSTGRES_PASSWORD=CHANGE_ME

JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTERS
AUTHCLAW_ENCRYPTION_KEY=GENERATE_WITH_FERNET_GENERATE_KEY

SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=no-reply@authclaw.example.com
SMTP_USE_TLS=true

AWS_SECRETS_MANAGER_ENABLED=true
AWS_REGION=us-east-1
AUTHCLAW_DOCUMENT_STORAGE_BACKEND=s3
AUTHCLAW_DOCUMENT_S3_BUCKET=authclaw-production-documents

AUTHCLAW_PROVIDER_OPENAI_SECRET_JSON=
AUTHCLAW_PROVIDER_ANTHROPIC_SECRET_JSON=
AUTHCLAW_PROVIDER_GEMINI_SECRET_JSON=
AUTHCLAW_PROVIDER_AZURE_OPENAI_SECRET_JSON=

AUTHCLAW_USE_COOKIES=false
AUTHCLAW_COOKIE_SECURE=true
AUTHCLAW_COOKIE_SAMESITE=strict

MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash-lite
GOOGLE_API_KEY=
