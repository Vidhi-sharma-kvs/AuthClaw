AUTHCLAW_ENV=production

# Direct EC2 testing origin. Replace with the frontend EC2 public endpoint.
# If Nginx serves the frontend on port 80:
# AUTHCLAW_ALLOWED_ORIGINS=http://<frontend-ec2-public-ip>
# If Vite preview/dev is exposed directly:
# AUTHCLAW_ALLOWED_ORIGINS=http://<frontend-ec2-public-ip>:5173
AUTHCLAW_ALLOWED_ORIGINS=http://<frontend-ec2-public-ip>

AUTHCLAW_RATE_LIMIT_PER_MINUTE=120
ENABLE_DEV_MODE=false
SKIP_EMAIL_DELIVERY_FOR_TESTING=false

# Testing only because there is no DNS/domain verification in this EC2 setup.
# Set this to false before real customer onboarding.
SKIP_DOMAIN_VERIFICATION=true

# Keep MFA enabled for realistic testing. Set true only for local emergency access.
DISABLE_MFA_FOR_TESTING=false

# RDS PostgreSQL db.t3.small connection string.
DATABASE_URL=postgresql://authclaw:<password>@<rds-endpoint>:5432/authclaw

# Generate these before deployment.
# JWT_SECRET: 32+ characters.
# AUTHCLAW_ENCRYPTION_KEY: Fernet key generated by Python cryptography.
JWT_SECRET=<replace-with-32-plus-character-secret>
AUTHCLAW_ENCRYPTION_KEY=<replace-with-fernet-key>

# SMTP uses SendGrid for direct EC2 testing. Verify a Single Sender in SendGrid first.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=<sendgrid-api-key>
SMTP_FROM=<verified-sendgrid-sender-email>
SMTP_USE_TLS=true

AWS_SECRETS_MANAGER_ENABLED=false
AWS_REGION=us-east-1

# Runtime fallback model configuration. Tenants should still connect their own provider credentials in the UI.
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash-lite
GOOGLE_API_KEY=<optional-bootstrap-gemini-key>

AUTHCLAW_USE_COOKIES=false
AUTHCLAW_COOKIE_SECURE=false
AUTHCLAW_COOKIE_SAMESITE=lax
