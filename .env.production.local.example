# AuthClaw local production-compose configuration.
# Copy this file to .env.production.local before running:
# docker compose -f docker-compose.production.yml up -d --build
#
# This file is for local production-style container testing only.
# AWS production deployment continues to use Terraform + AWS Secrets Manager/KMS.

AUTHCLAW_ENV=production-local
AUTHCLAW_SECRET_BACKEND=local_env
AUTHCLAW_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:5173,http://localhost:5173
AUTHCLAW_RATE_LIMIT_PER_MINUTE=120
ENABLE_DEV_MODE=false
SKIP_EMAIL_DELIVERY_FOR_TESTING=false
SKIP_DOMAIN_VERIFICATION=true
DISABLE_MFA_FOR_TESTING=false
AUTHCLAW_SOFT_FAIL_EMAIL_DELIVERY=true
AUTHCLAW_DISABLE_BACKGROUND_MONITOR=true
AUTHCLAW_DISABLE_REMOTE_EMBEDDINGS=true

DATABASE_URL=postgresql://authclaw:authclaw_local_password@postgres:5432/authclaw
POSTGRES_PASSWORD=authclaw_local_password

JWT_SECRET=local_production_jwt_secret_change_me_48_characters_min
AUTHCLAW_ENCRYPTION_KEY=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
AUTHCLAW_REDACTION_SALT=local_production_redaction_salt_change_me_48_chars_min

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=local-dev-smtp-user
SMTP_PASSWORD=local-dev-smtp-password
SMTP_FROM=no-reply@authclaw.local
SMTP_USE_TLS=false
SENDGRID_API_KEY=

AWS_SECRETS_MANAGER_ENABLED=false
AWS_REGION=us-east-1
AUTHCLAW_DOCUMENT_STORAGE_BACKEND=local
AUTHCLAW_DOCUMENT_S3_BUCKET=

AUTHCLAW_PROVIDER_OPENAI_SECRET_JSON=
AUTHCLAW_PROVIDER_ANTHROPIC_SECRET_JSON=
AUTHCLAW_PROVIDER_GEMINI_SECRET_JSON=
AUTHCLAW_PROVIDER_AZURE_OPENAI_SECRET_JSON=

AUTHCLAW_USE_COOKIES=false
AUTHCLAW_COOKIE_SECURE=false
AUTHCLAW_COOKIE_SAMESITE=lax

MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash-lite
GOOGLE_API_URL=https://generativelanguage.googleapis.com
GOOGLE_API_KEY=

VITE_API_BASE_URL=/api
VITE_GATEWAY_PUBLIC_URL=/api
