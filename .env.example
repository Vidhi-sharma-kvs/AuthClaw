# AuthClaw local development template.
# Copy to .env and replace every placeholder before running services.
# Never commit real secrets.

AUTHCLAW_ENV=development
AUTHCLAW_SECRET_BACKEND=local_env

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/authclaw

# Core secrets
JWT_SECRET=<set-in-secret-manager>
AUTHCLAW_ENCRYPTION_KEY=<set-in-secret-manager>
AUTHCLAW_HASH_SALT=<set-in-secret-manager>

# CORS / URLs
AUTHCLAW_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE_URL=/api
VITE_GATEWAY_PUBLIC_URL=http://127.0.0.1:9000

# Provider defaults
MODEL_PROVIDER=openai
MODEL_NAME=gpt-4o
AUTHCLAW_ALLOW_LOCAL_PROVIDER_FALLBACK=true
GOOGLE_API_KEY=<set-in-secret-manager>
OPENAI_API_KEY=<set-in-secret-manager>
ANTHROPIC_API_KEY=<set-in-secret-manager>
COHERE_API_KEY=<set-in-secret-manager>
AZURE_OPENAI_API_KEY=<set-in-secret-manager>
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o-production

# Email delivery
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=<set-in-secret-manager>
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true

# Local-only toggles. Keep false for production.
SKIP_DOMAIN_VERIFICATION=false
SKIP_EMAIL_DELIVERY_FOR_TESTING=false
DISABLE_MFA_FOR_TESTING=false
AUTHCLAW_DISABLE_BACKGROUND_MONITOR=false
AUTHCLAW_DISABLE_REMOTE_EMBEDDINGS=false
